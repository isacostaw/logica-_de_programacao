programa {
  funcao inicio() {
    inteiro num [5]
    escreva ("qual o número da primeira posição?")
    leia(num[0])
     escreva ("qual o número da segunda posição?")
    leia(num[1])
     escreva ("qual o número da terceira posição?")
    leia(num[2])
    
    num[3]=5
    num[4]=20
    
    escreva(num)
  }
}
