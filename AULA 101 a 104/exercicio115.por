programa {
  funcao inicio() {
    inteiro numero [4] ={6,5,2,3}
    inteiro soma,multiplicacao, diferenca
    soma = numero[0] + numero[3]
    diferenca = numero[2] - numero[0]
    multiplicacao = numero[1] * numero[0]

      escreva ("qual a soma entre os números : ",soma,"\n")
      escreva ("qual a diferenca entre os números : ",diferenca,"\n")
      escreva ("qual a multiplicação entre os números : ",multiplicacao,"\n")
}
}
  

