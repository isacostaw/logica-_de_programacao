programa {
  funcao inicio() {
    real velocidade 
    const real limiteDaVia =60


    escreva ("qual a velocidade do veículo")
    leia (velocidade)
     

    se (velocidade>limiteDaVia){
      escreva ("multa deve ser aplicada ")

    }
    senao{
      escreva("no limite da via ")
    }
  }
}
