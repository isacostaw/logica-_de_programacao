programa
{
    funcao inicio()
    {
        inteiro numero

        escreva ("Qual o numero ?")
        leia(numero)

        se (numero > 0)
        {
            escreva("Numero positivo")
        }
    }
    // estava faltando o escreva para indicar qual numero entraria como dado 
    // no se havia um erro na indicação matemática  de qual seria o maior para que o numero fosse considerado positivo 
}