programa
{
    funcao inicio()
    {
        real  largura, altura
        real area
      escreva ("Qual a largura ? ")
        leia(largura)

        escreva("Qual a altura ? ")
        leia(altura)

        area = largura * altura

        escreva("Área: ", area)
    }
    //A variavel largura e altura deveriam ser indicadas como real para que pudesse ser colocados números em decimais 
    //estava faltando o escreva para declarar a entrada dos dados de entrada da largura e altura 
}