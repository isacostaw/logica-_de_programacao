programa
{
    funcao inicio()
    {
        real n1, n2, media
        escreva ("Qual o numero 1? ")
        leia(n1)

        escreva ("Qual o numero 2? ")
        leia(n2)

        media = (n1 + n2) / 2

        escreva("Média: ", media)
        // havia um erro de usabilidade faltando o escreva, com isso na era possive indicar qual a entrada de dados
        //erro na operação que seria realizada, a soma dos numero deveria ser dividida por 2 e estva por 3
    }
}
