programa
{
    funcao inicio()
    {
        inteiro a, b, soma

        escreva("Digite A: ")
        leia(a)


        escreva("Digite B: ")
        leia(b)

        soma = a + b

        escreva("Soma = ", soma)

        //erro na operação pois ao invés de somar a e b estava multiplicando essas variéveis
    }
}