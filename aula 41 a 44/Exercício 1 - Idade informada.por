programa {
  funcao inicio() {
    inteiro idade
    escreva ("Qual a idade ? ")
    leia(idade)

    escreva("Idade informada: ", idade)
    //estava faltando o escreva para indicar a entrada de dados 
    // e o zero seria considerado uma idade constante pois nao havia a indicação da váriavel idade 
  }
}
